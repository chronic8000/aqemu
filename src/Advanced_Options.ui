<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Advanced_Options</class>
 <widget class="QDialog" name="Advanced_Options">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>553</width>
    <height>1180</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Advanced Options</string>
  </property>
  <layout class="QGridLayout" name="gridLayout_3">
   <item row="0" column="0">
    <widget class="QGroupBox" name="groupBox_options">
     <property name="title">
      <string>Advanced Options</string>
     </property>
     <layout class="QGridLayout" name="gridLayout">
      <item row="1" column="0">
       <widget class="QCheckBox" name="CH_RTC_TD_Hack">
        <property name="text">
         <string>RTC TD hack (Fixes time drift in windows ACPI HAL)</string>
        </property>
       </widget>
      </item>
      <item row="2" column="0">
       <widget class="QCheckBox" name="CH_No_Shutdown">
        <property name="text">
         <string>No shutdown</string>
        </property>
       </widget>
      </item>
      <item row="3" column="0">
       <widget class="QCheckBox" name="CH_No_Reboot">
        <property name="toolTip">
         <string>Exit instead of rebooting</string>
        </property>
        <property name="text">
         <string>No reboot</string>
        </property>
       </widget>
      </item>
      <item row="4" column="0">
       <widget class="QCheckBox" name="CH_Start_CPU">
        <property name="text">
         <string>Start CP&amp;U at startup</string>
        </property>
       </widget>
      </item>
      <item row="5" column="0">
       <widget class="QCheckBox" name="CH_FDD_Boot">
        <property name="toolTip">
         <string>Check Floppy Disk boot signature in VM BIOS</string>
        </property>
        <property name="text">
         <string>Check boot secto&amp;r on FDD</string>
        </property>
       </widget>
      </item>
      <item row="6" column="0">
       <widget class="QCheckBox" name="CH_ACPI">
        <property name="sizePolicy">
         <sizepolicy hsizetype="Minimum" vsizetype="Fixed">
          <horstretch>0</horstretch>
          <verstretch>0</verstretch>
         </sizepolicy>
        </property>
        <property name="text">
         <string>Enable ACP&amp;I</string>
        </property>
       </widget>
      </item>
      <item row="6" column="1">
       <widget class="QCheckBox" name="CH_Force_TCG">
        <property name="toolTip">
         <string>Windows 95/98 and earlier: use pure TCG only (no WHPX/KVM). Fixes splash-screen freezes on Windows hosts.</string>
        </property>
        <property name="text">
         <string>Force pure TCG (Win9x / pre-ME)</string>
        </property>
       </widget>
      </item>
      <item row="7" column="0" colspan="2">
       <widget class="QCheckBox" name="CH_Pass_Through_Gamepads">
        <property name="toolTip">
         <string>Pass through connected Xbox, PlayStation, Nintendo, and other USB game controllers into the guest via QEMU usb-host (vendor/product ID). Requires a QEMU build with USB host support. On Windows, AQEMU enumerates PnP USB devices.</string>
        </property>
        <property name="text">
         <string>Pass through Xbox / USB game controllers</string>
        </property>
       </widget>
      </item>
      <item row="8" column="0" colspan="2">
       <layout class="QHBoxLayout" name="HL_Gamepads">
        <item>
         <widget class="QListWidget" name="LW_Gamepads">
          <property name="toolTip">
           <string>Leave all unchecked to pass through every detected gamepad. Check specific controllers to limit passthrough.</string>
          </property>
          <property name="maximumSize">
           <size>
            <width>16777215</width>
            <height>72</height>
           </size>
          </property>
          <property name="selectionMode">
           <enum>QAbstractItemView::NoSelection</enum>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QToolButton" name="TB_Refresh_Gamepads">
          <property name="toolTip">
           <string>Rescan host USB for game controllers</string>
          </property>
          <property name="text">
           <string>Refresh</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item row="9" column="0" colspan="2">
       <widget class="QCheckBox" name="CH_Emulate_USB_Gamepad">
        <property name="toolTip">
         <string>Add QEMU's emulated usb-gamepad device (maps a host joystick/gamepad into the guest as USB HID). Not present in every QEMU build — if Start fails, use USB passthrough above instead. Best for guests that expect a generic USB gamepad rather than an Xbox XInput device.</string>
        </property>
        <property name="text">
         <string>Emulate USB gamepad (usb-gamepad / host SDL)</string>
        </property>
       </widget>
      </item>
      <item row="10" column="0">
       <widget class="QCheckBox" name="CH_VirtIO_Balloon">
        <property name="toolTip">
         <string>Paravirtual memory balloon (-device virtio-balloon-pci). Lets the guest return unused RAM to the host.</string>
        </property>
        <property name="text">
         <string>VirtIO balloon</string>
        </property>
       </widget>
      </item>
      <item row="10" column="1">
       <widget class="QCheckBox" name="CH_VirtIO_RNG">
        <property name="toolTip">
         <string>Paravirtual entropy device (-device virtio-rng-pci). Speeds up guest boot when entropy is scarce.</string>
        </property>
        <property name="text">
         <string>VirtIO RNG</string>
        </property>
       </widget>
      </item>
      <item row="11" column="0">
       <widget class="QCheckBox" name="CH_VirtIO_Keyboard">
        <property name="toolTip">
         <string>Add virtio-keyboard-pci (useful on aarch64 virt / modern guests).</string>
        </property>
        <property name="text">
         <string>VirtIO keyboard</string>
        </property>
       </widget>
      </item>
      <item row="11" column="1">
       <widget class="QCheckBox" name="CH_No_Defaults">
        <property name="toolTip">
         <string>Pass -nodefaults so QEMU does not create default devices. You must define video, network, serial, etc. yourself (Additional Args / Device Manager). Useful for bare boards and custom machines.</string>
        </property>
        <property name="text">
         <string>No default devices (-nodefaults)</string>
        </property>
       </widget>
      </item>
      <item row="12" column="0">
       <widget class="QLabel" name="Label_RTC_Clock">
        <property name="text">
         <string>Guest RTC clock:</string>
        </property>
       </widget>
      </item>
      <item row="12" column="1">
       <widget class="QComboBox" name="CB_RTC_Clock">
        <property name="toolTip">
         <string>-rtc clock=… — host tracks the host clock; vm isolates the guest; rt uses a realtime clock independent of host suspension.</string>
        </property>
        <item>
         <property name="text">
          <string>host (default)</string>
         </property>
        </item>
        <item>
         <property name="text">
          <string>vm (isolate from host)</string>
         </property>
        </item>
        <item>
         <property name="text">
          <string>rt (realtime)</string>
         </property>
        </item>
       </widget>
      </item>
      <item row="13" column="0">
       <widget class="QCheckBox" name="CH_IOThread">
        <property name="toolTip">
         <string>Creates -object iothread,id=aq-iothread0 and attaches it to virtio-blk devices for better disk I/O on SMP hosts (qemu-doc / modern -drive+device).</string>
        </property>
        <property name="text">
         <string>IOThread for VirtIO disks</string>
        </property>
       </widget>
      </item>
      <item row="13" column="1">
       <widget class="QCheckBox" name="CH_Modern_Netdev">
        <property name="toolTip">
         <string>Emit modern -netdev + -device for user/tap/bridge instead of legacy -net (recommended). Uncheck only if an old QEMU needs -net.</string>
        </property>
        <property name="text">
         <string>Modern -netdev networking</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
       </widget>
      </item>
